<?php
include "db.php";

$critical=$conn->query("SELECT COUNT(*) as total FROM hosts WHERE score <50")
->fetch_assoc()['total'];

$medium=$conn->query("SELECT COUNT(*) as total FROM hosts WHERE score BETWEEN 50 AND 79")
->fetch_assoc()['total'];

$secure=$conn->query("SELECT COUNT(*) as total FROM hosts WHERE score >=80")
->fetch_assoc()['total'];
?>

<!DOCTYPE html>
<html>

<head>

